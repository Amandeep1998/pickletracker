PORT=5000
MONGO_URI=
JWT_SECRET=
OPENAI_API_KEY=

# Web Push (VAPID) — generate keys: node -e "require('web-push').generateVAPIDKeys()|console.log"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# WhatsApp Business API (Meta Cloud API)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=           # Permanent token from Meta App → WhatsApp → API Setup
WHATSAPP_PHONE_ID=        # Phone Number ID from Meta App → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=    # Any secret string you choose — used to verify the webhook URL
WHATSAPP_BUSINESS_NUMBER= # Your WhatsApp business number without + (e.g. 911234567890) — shown to users so they can initiate the chat

# Admin panel — email address that can access /api/admin routes
ADMIN_EMAIL=

# Public frontend URL — used in email links (tournament reminders, etc.)
APP_PUBLIC_URL=https://pickletracker.in

# Google sign-in — set on the API host (Render, Railway, VPS, etc.). Not used by Vercel static frontend.
# Download JSON: Firebase Console → Project settings → Service accounts → Generate new private key
#
# Option A — full JSON as one line (escape inner quotes if needed):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Option B — base64 of the file (recommended; generate: base64 -i serviceAccount.json | tr -d '\n'):
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# (alias on Render: FIREBASE_SERVICE_ACCOUNT_BASE64 — same value)
#
# Option C — local file only (development):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
