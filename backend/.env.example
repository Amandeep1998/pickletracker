PORT=5000
MONGO_URI=
JWT_SECRET=
OPENAI_API_KEY=

# Admin panel — email address that can access /api/admin routes
ADMIN_EMAIL=

# Google sign-in — set on the API host (Render, Railway, VPS, etc.). Not used by Vercel static frontend.
# Download JSON: Firebase Console → Project settings → Service accounts → Generate new private key
#
# Option A — full JSON as one line (escape inner quotes if needed):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Option B — base64 of the file (recommended; generate: base64 -i serviceAccount.json | tr -d '\n'):
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# (alias on Render: FIREBASE_SERVICE_ACCOUNT_BASE64 — same value)
#
# Option C — local file only (development):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
